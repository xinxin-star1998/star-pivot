<?xml version="1.0" encoding="UTF-8"?>
<!--
    Logback 日志配置文件
    
    说明：
    - 支持按环境（dev/test/prod）配置不同的日志级别
    - 日志文件滚动：按日期和大小滚动
    - 控制台输出：开发环境输出到控制台，生产环境仅输出到文件
    - 异步日志：提升性能，避免阻塞主线程
    
    配置项：
    - ${LOG_PATH:logs}：日志文件路径，可通过环境变量 LOG_PATH 配置
    - ${LOG_LEVEL:INFO}：日志级别，可通过环境变量 LOG_LEVEL 配置
-->
<configuration>
    <!-- 引入 Spring Boot 默认配置 -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- 日志文件路径（可通过环境变量配置） -->
    <property name="LOG_PATH" value="${LOG_PATH:-logs}"/>
    
    <!-- 应用名称 -->
    <property name="APP_NAME" value="star-pivot"/>

    <!-- 控制台输出（开发环境） -->
    <springProfile name="dev,test">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>
    </springProfile>

    <!-- 文件输出（所有环境） -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${APP_NAME}.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- 日志文件命名格式：按日期和大小滚动 -->
            <fileNamePattern>${LOG_PATH}/${APP_NAME}.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <!-- 单个日志文件最大大小 -->
            <maxFileSize>100MB</maxFileSize>
            <!-- 保留历史日志天数 -->
            <maxHistory>30</maxHistory>
            <!-- 所有日志文件总大小限制 -->
            <totalSizeCap>3GB</totalSizeCap>
            <!-- 日志文件清理时，删除超过保留天数的文件 -->
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
    </appender>

    <!-- 错误日志单独输出 -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${APP_NAME}-error.log</file>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${APP_NAME}-error.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>60</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
    </appender>

    <!-- 异步日志（提升性能） -->
    <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <!-- 不丢失日志，如果队列满了，会阻塞直到队列有空间 -->
        <discardingThreshold>0</discardingThreshold>
        <!-- 队列大小 -->
        <queueSize>512</queueSize>
        <!-- 是否提取调用者数据 -->
        <includeCallerData>false</includeCallerData>
        <appender-ref ref="FILE"/>
    </appender>

    <appender name="ASYNC_ERROR_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <discardingThreshold>0</discardingThreshold>
        <queueSize>256</queueSize>
        <includeCallerData>true</includeCallerData>
        <appender-ref ref="ERROR_FILE"/>
    </appender>

    <!-- 开发环境：控制台 + 文件 -->
    <springProfile name="dev">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_FILE"/>
            <appender-ref ref="ASYNC_ERROR_FILE"/>
        </root>
        <!-- 项目包日志级别 -->
        <logger name="com.star.pivot" level="DEBUG"/>
        <!-- Spring Security 日志 -->
        <logger name="org.springframework.security" level="DEBUG"/>
        <!-- SQL 日志 -->
        <logger name="org.apache.ibatis" level="DEBUG"/>
        <!-- MyBatis-Plus 日志 -->
        <logger name="com.baomidou.mybatisplus" level="WARN"/>
    </springProfile>

    <!-- 测试环境：仅文件 -->
    <springProfile name="test">
        <root level="INFO">
            <appender-ref ref="ASYNC_FILE"/>
            <appender-ref ref="ASYNC_ERROR_FILE"/>
        </root>
        <logger name="com.star.pivot" level="DEBUG"/>
        <logger name="org.springframework.security" level="INFO"/>
        <logger name="org.apache.ibatis" level="INFO"/>
        <logger name="com.baomidou.mybatisplus" level="WARN"/>
    </springProfile>

    <!-- 生产环境：仅文件，日志级别较高 -->
    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="ASYNC_FILE"/>
            <appender-ref ref="ASYNC_ERROR_FILE"/>
        </root>
        <!-- 生产环境使用 INFO 级别，减少日志量 -->
        <logger name="com.star.pivot" level="INFO"/>
        <logger name="org.springframework" level="WARN"/>
        <logger name="org.springframework.security" level="WARN"/>
        <logger name="org.apache.ibatis" level="WARN"/>
        <logger name="com.baomidou.mybatisplus" level="WARN"/>
        <!-- 第三方库日志级别 -->
        <logger name="org.apache" level="WARN"/>
        <logger name="com.alibaba" level="WARN"/>
    </springProfile>

    <!-- 默认配置（未指定环境时） -->
    <springProfile name="!dev,!test,!prod">
        <root level="INFO">
            <appender-ref ref="ASYNC_FILE"/>
            <appender-ref ref="ASYNC_ERROR_FILE"/>
        </root>
    </springProfile>
</configuration>
