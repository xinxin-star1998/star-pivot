<?xml version="1.0" encoding="UTF-8"?>
<!--
    Logback 日志配置文件（控制台输出优化）

    说明：
    - local/dev/test：控制台彩色输出 + 文件；prod 仅文件
    - 控制台格式：时间(淡色) 线程(紫) 级别  logger(青) 消息，便于扫读
    - MyBatis SQL 建议走 Slf4jImpl，由本配置统一级别与格式
    - 异步文件日志，includeCallerData=false 降低开销
    - 配置项：LOG_PATH、LOG_LEVEL 等可通过环境变量覆盖
-->
<configuration>
    <!-- 引入 Spring Boot 默认配置 -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- 日志文件路径（可通过环境变量配置） -->
    <property name="LOG_PATH" value="${LOG_PATH:-logs}"/>
    
    <!-- 应用名称 -->
    <property name="APP_NAME" value="star-pivot"/>

    <!-- 控制台输出（local/dev）：仅 INFO 及以上，不刷屏 DEBUG/SQL/Security -->
    <springProfile name="local,dev,test">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
                <level>INFO</level>
            </filter>
            <encoder>
                <pattern>%clr(%d{yyyy-MM-dd HH:mm:ss.SSS}){faint} %clr([%thread]){magenta} %clr(%-5level) %clr(%logger{50}){cyan} - %msg%n</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>
    </springProfile>

    <!-- 文件输出（所有环境） -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${APP_NAME}.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- 日志文件命名格式：按日期和大小滚动 -->
            <fileNamePattern>${LOG_PATH}/${APP_NAME}.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <!-- 单个日志文件最大大小 -->
            <maxFileSize>100MB</maxFileSize>
            <!-- 保留历史日志天数 -->
            <maxHistory>30</maxHistory>
            <!-- 所有日志文件总大小限制 -->
            <totalSizeCap>3GB</totalSizeCap>
            <!-- 日志文件清理时，删除超过保留天数的文件 -->
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
    </appender>

    <!-- 错误日志单独输出 -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${APP_NAME}-error.log</file>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${APP_NAME}-error.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>60</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
    </appender>

    <!-- 异步日志（提升性能） -->
    <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <!-- 不丢失日志，如果队列满了，会阻塞直到队列有空间 -->
        <discardingThreshold>0</discardingThreshold>
        <!-- 队列大小 -->
        <queueSize>512</queueSize>
        <!-- 是否提取调用者数据 -->
        <includeCallerData>false</includeCallerData>
        <appender-ref ref="FILE"/>
    </appender>

    <appender name="ASYNC_ERROR_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <discardingThreshold>0</discardingThreshold>
        <queueSize>256</queueSize>
        <!-- 仅错误日志需要调用栈时可设为 true，生产可关以减开销 -->
        <includeCallerData>false</includeCallerData>
        <appender-ref ref="ERROR_FILE"/>
    </appender>

    <!-- local 环境：控制台仅 INFO+，文件保留 DEBUG；框架日志 INFO 减少噪音 -->
    <springProfile name="local">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_FILE"/>
            <appender-ref ref="ASYNC_ERROR_FILE"/>
        </root>
        <logger name="com.star.pivot" level="INFO"/>
        <logger name="org.springframework.security" level="WARN"/>
        <logger name="org.apache.ibatis" level="WARN"/>
        <logger name="com.baomidou.mybatisplus" level="WARN"/>
    </springProfile>

    <!-- 开发环境：同上，控制台干净、文件可单独开 DEBUG -->
    <springProfile name="dev">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_FILE"/>
            <appender-ref ref="ASYNC_ERROR_FILE"/>
        </root>
        <logger name="com.star.pivot" level="INFO"/>
        <logger name="org.springframework.security" level="WARN"/>
        <logger name="org.apache.ibatis" level="WARN"/>
        <logger name="com.baomidou.mybatisplus" level="WARN"/>
    </springProfile>

    <!-- 测试环境：仅文件 -->
    <springProfile name="test">
        <root level="INFO">
            <appender-ref ref="ASYNC_FILE"/>
            <appender-ref ref="ASYNC_ERROR_FILE"/>
        </root>
        <logger name="com.star.pivot" level="DEBUG"/>
        <logger name="org.springframework.security" level="INFO"/>
        <logger name="org.apache.ibatis" level="INFO"/>
        <logger name="com.baomidou.mybatisplus" level="WARN"/>
    </springProfile>

    <!-- 生产环境：仅文件，日志级别较高 -->
    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="ASYNC_FILE"/>
            <appender-ref ref="ASYNC_ERROR_FILE"/>
        </root>
        <!-- 生产环境使用 INFO 级别，减少日志量 -->
        <logger name="com.star.pivot" level="INFO"/>
        <logger name="org.springframework" level="WARN"/>
        <logger name="org.springframework.security" level="WARN"/>
        <logger name="org.apache.ibatis" level="WARN"/>
        <logger name="com.baomidou.mybatisplus" level="WARN"/>
        <!-- 第三方库日志级别 -->
        <logger name="org.apache" level="WARN"/>
        <logger name="com.alibaba" level="WARN"/>
    </springProfile>

    <!-- 默认配置（未指定 profile 时仅文件，无控制台） -->
    <springProfile name="!local,!dev,!test,!prod">
        <root level="INFO">
            <appender-ref ref="ASYNC_FILE"/>
            <appender-ref ref="ASYNC_ERROR_FILE"/>
        </root>
    </springProfile>
</configuration>
