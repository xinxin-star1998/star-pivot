#!/usr/bin/env sh

MSG_FILE="$1"
ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
UI_DIR="$ROOT_DIR/star-pivot-ui"
COMMITLINT_CLI="$UI_DIR/node_modules/@commitlint/cli/cli.js"

# JetBrains/Git for Windows sometimes cannot resolve node from PATH in hooks.
if [ -x "/e/nvm/nodejs/node.exe" ]; then
  NODE_EXE="/e/nvm/nodejs/node.exe"
else
  NODE_EXE="node"
fi

cd "$UI_DIR" || exit 1
"$NODE_EXE" "$COMMITLINT_CLI" --config commitlint.config.cjs --edit "$MSG_FILE"
