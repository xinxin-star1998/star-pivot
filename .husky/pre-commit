#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo "Running pre-commit checks..."

# 检查是否有暂存的文件
if git diff --cached --quiet; then
  echo "No staged files. Skipping pre-commit checks."
  exit 0
fi

# 获取暂存的文件
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# 检查是否有 Java 文件
JAVA_FILES=$(echo "$STAGED_FILES" | grep -E '\.java$' || true)
if [ -n "$JAVA_FILES" ]; then
  echo "Checking Java files..."
  mvn spotless:check -pl star-pivot-controller -am -q
  if [ $? -ne 0 ]; then
    echo "❌ Spotless check failed! Run 'mvn spotless:apply' to fix."
    exit 1
  fi
  echo "✅ Java files formatted correctly"
fi

# 检查是否有前端文件
FRONTEND_FILES=$(echo "$STAGED_FILES" | grep -E '\.(ts|js|vue|css|scss)$' || true)
if [ -n "$FRONTEND_FILES" ]; then
  echo "Checking frontend files..."
  cd star-pivot-ui
  
  # ESLint 检查
  npx eslint --quiet $FRONTEND_FILES
  if [ $? -ne 0 ]; then
    echo "❌ ESLint check failed! Run 'npm run fix' to fix."
    exit 1
  fi
  echo "✅ ESLint check passed"
  
  # Prettier 检查
  npx prettier --check $FRONTEND_FILES
  if [ $? -ne 0 ]; then
    echo "❌ Prettier check failed! Run 'npm run lint:prettier' to fix."
    exit 1
  fi
  echo "✅ Prettier check passed"
  
  # Stylelint 检查
  STYLE_FILES=$(echo "$FRONTEND_FILES" | grep -E '\.(css|scss|vue)$' || true)
  if [ -n "$STYLE_FILES" ]; then
    npx stylelint --quiet $STYLE_FILES
    if [ $? -ne 0 ]; then
      echo "❌ Stylelint check failed! Run 'npm run lint:stylelint' to fix."
      exit 1
    fi
    echo "✅ Stylelint check passed"
  fi
  
  cd ..
fi

echo "✅ All pre-commit checks passed!"
