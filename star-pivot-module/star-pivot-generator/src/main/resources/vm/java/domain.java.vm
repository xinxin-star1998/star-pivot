package ${packageName}.domain.entity;

#foreach ($import in $importList)
import ${import};
#end
import com.baomidou.mybatisplus.annotation.IdType;
import com.baomidou.mybatisplus.annotation.TableId;
import com.baomidou.mybatisplus.annotation.TableName;
import lombok.Data;
import com.star.pivot.framework.domain.BaseEntity;
#if($table.tree)
import com.star.pivot.framework.domain.TreeEntity;
#end

/**
 * ${functionName}实体类 ${tableName}
 * 
 * @author ${author}
 * @since ${datetime}
 */
@Data
@TableName("${tableName}" )
#if($table.crud || $table.sub)
public class ${ClassName} extends BaseEntity
#elseif($table.tree)
public class ${ClassName} extends TreeEntity
#end
{
    private static final long serialVersionUID = 1L;

#foreach ($column in $columns)
#if(!$table.isSuperColumn($column.javaField))
    /**
     * $column.columnComment
     */
    #if($column.pk)
    @TableId(value = "$column.columnName" , type = IdType.AUTO)
    #end
    private $column.javaType $column.javaField;

#end
#end
#if($table.sub)
    /**
     * ${subTable.functionName}信息列表
     */
    private List<${subClassName}> ${subclassName}List;

#end
}
